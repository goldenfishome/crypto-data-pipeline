# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Redshift Serverless
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DB=crypto_pipeline
REDSHIFT_USER=
REDSHIFT_PASSWORD=

# S3
RAW_BUCKET_NAME=crypto-pipeline-raw

# IAM role ARN that Redshift uses to read from S3 (from terraform output: redshift_iam_role_arn)
REDSHIFT_IAM_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/crypto-pipeline-redshift-s3

# Binance WebSocket endpoint (binance.us for US users, stream.binance.com:9443 outside US)
BINANCE_WS_BASE=wss://stream.binance.us:9443/stream

# Pipeline config
COINS_LIMIT=20
BINANCE_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT

# Local dev — if set, writes Parquet to local filesystem instead of S3
# LOCAL_RAW_PATH=/tmp/crypto-pipeline-raw

# Copy to ~/.dbt/profiles.yml and fill in your values.
# Never commit the real profiles.yml — it contains credentials.

crypto_pipeline:
  target: dev
  outputs:
    dev:
      type: redshift
      host: "{{ env_var('REDSHIFT_HOST') }}"
      port: 5439
      user: "{{ env_var('REDSHIFT_USER') }}"
      password: "{{ env_var('REDSHIFT_PASSWORD') }}"
      dbname: "{{ env_var('REDSHIFT_DB', 'crypto_pipeline') }}"
      schema: staging
      threads: 4
      connect_timeout: 30
